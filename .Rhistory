prime
from Indices import generate
from collections import defaultdict
def clean_label(label):
"""Convert underscores to spaces and capitalize words."""
if isinstance(label, str):
return label.replace("_", " ").capitalize()
elif isinstance(label, list):
return [clean_label(l) for l in label]
return label
# Generate exercises
data = generate(
types=[
"multiply_simple",
"multiply_three_terms",
"multiply_coefficients",
"fractional_nonunit",
"combine_same_power",
],
seed=42,
count=6,
show_solutions=False,
)
exercises = data["exercises"]
ws = data.get("worksheet", {})
# Group exercises by difficulty and clean metadata
grouped = defaultdict(list)
for ex in exercises:
meta = ex.get("meta", {})
ex["meta_clean"] = {
"topic": clean_label(meta.get("topic", "Indices")),
"skills": clean_label(meta.get("skills", ["Index Laws"]))
}
grouped[meta.get("difficulty", "medium")].append(ex)
# Now grouped is ready for rendering in QMD

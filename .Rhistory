# Import generator
from Indices import generate
from collections import defaultdict
# Generate exercises
data = generate(
types=["multiply_simple", "multiply_coefficients"],
seed=42,
count=6,
show_solutions=False
)
exercises = data["exercises"]
# Group by difficulty
grouped = defaultdict(list)
for ex in exercises:
grouped[ex["meta"]["difficulty"]].append(ex)
for ex in grouped.get("hard", []):
print(f"### Question {ex['number']}: {ex['title']}\n")
print(f"{ex['instruction']}\n")
parts = "  \n".join(f"({p['label']}) ${p['question_latex']}$" for p in ex["parts"])
print(parts + "\n")
for ex in grouped.get("medium", []):
print(f"### Question {ex['number']}: {ex['title']}\n")
print(f"{ex['instruction']}\n")
parts = "  \n".join(f"({p['label']}) ${p['question_latex']}$" for p in ex["parts"])
print(parts + "\n")
for ex in grouped.get("easy", []):
print(f"### Question {ex['number']}: {ex['title']}\n")
print(f"{ex['instruction']}\n")
# Combine all parts in one block
# Wrap each part in inline or display math
for p in ex["parts"]:
# Use $$...$$ for display math
print(f"({p['label']}) $$ {p['question_latex']} $$\n")
for ex in grouped.get("easy", []):
print(f"### Question {ex['number']}: {ex['title']}\n")
print(f"{ex['instruction']}\n")
# Use 'results="asis"' to output proper Markdown/LaTeX
parts = "  \n".join(f"({p['label']}) ${p['question_latex']}$" for p in ex["parts"])
print(parts + "\n")
for ex in grouped.get("easy", []):
print(f"### Question {ex['number']}: {ex['title']}\n")
print(f"{ex['instruction']}\n")
# Use 'results="asis"' to output proper Markdown/LaTeX
parts = "  \n".join(f"({p['label']}) ${p['question_latex']}$" for p in ex["parts"])
print(parts + "\n")
for ex in grouped.get("easy", []):
print(f"### Question {ex['number']}: {ex['title']}\n")
print(f"{ex['instruction']}\n")
# Use 'results="asis"' to output proper Markdown/LaTeX
parts = "  \n".join(f"({p['label']}) ${p['question_latex']}$" for p in ex["parts"])
print(parts + "\n")
for ex in grouped.get("easy", []):
print(f"### Question {ex['number']}: {ex['title']}\n")
print(f"{ex['instruction']}\n")
for p in ex["parts"]:
# Display math: leave it as raw LaTeX without $$ inside string
print(f"({p['label']}) {p['question_latex']}\n")
for ex in grouped.get("easy", []):
print(f"### Question {ex['number']}: {ex['title']}\n")
print(f"{ex['instruction']}\n")
for p in ex["parts"]:
# Wrap in $$ for display math
print(f"({p['label']}) $$ {p['question_latex']} $$\n")
for ex in grouped.get("easy", []):
print(f"### Question {ex['number']}: {ex['title']}\n")
print(f"{ex['instruction']}\n")
for p in ex["parts"]:
# Wrap in $$ for display math
print(f"({p['label']}) $$ {p['question_latex']} $$\n")

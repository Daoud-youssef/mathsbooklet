import sys
sys.path.insert(0, '/unit2-Indices')
from Indices import generate
from collections import defaultdict
# --------------------------
# Generate Exercises
# --------------------------
data = generate(
types=[
"multiply_simple",
"multiply_three_terms",
"multiply_coefficients",
"fractional_nonunit",
"combine_same_power",
],
seed           = 42,
count          = 6,
show_solutions = False,
)
exercises = data["exercises"]
ws        = data["worksheet"]
# --------------------------
# Clean metadata
# --------------------------
def clean_skills(skills):
return [s.replace("_", " ").capitalize() for s in skills]
for ex in exercises:
ex['meta_clean'] = {
'topic': ex['meta'].get('topic','Indices').replace("_"," ").capitalize(),
'skills': clean_skills(ex['meta'].get('skills', ['Index Laws']))
}
# --------------------------
# Group by difficulty
# --------------------------
grouped = defaultdict(list)
for ex in exercises:
grouped[ex["meta"]["difficulty"]].append(ex)
# --------------------------
# Function to render exercises
# --------------------------
def render_exercises(group, level):
#| output: asis
for ex in group.get(level, []):
print(f"::::: {{#exr-u2-{ex['number']}}}\n")
print(f"### {ex['title']}\n")
print(f"{ex['instruction']}\n")
# Question Parts
for p in ex["parts"]:
# Use display math for wide/long questions or hard level
math_delim = "$$" if p.get("is_wide") or level=="hard" else "$"
print(f"{p['label']})  {math_delim}{p['question_latex']}{math_delim}  ")
print("\n")
# Solution Callout
print('::: {.callout-tip collapse="true"}\n## 🔍 View Solution\n')
for p in ex["parts"]:
math_delim = "$$" if p.get("is_wide") or level=="hard" else "$"
print(f"{p['label']})  {math_delim}{p['answer_latex']}{math_delim}  ")
print(":::\n")
# Metadata Footer
skills_str = "  \n".join(ex['meta_clean']['skills'])
print(f"::: exercise-meta")
print(f"[Topic: {ex['meta_clean']['topic']}]{{.badge .topic-badge}} [Skills: {skills_str}]{{.badge .skill-badge}}")
print(":::\n")
print(":::::\n\n")

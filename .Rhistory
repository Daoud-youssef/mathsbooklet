sys.path.insert(0, '../unit2-Indices')
from Indices import generate
from collections import defaultdict
# --------------------------
# Generate Exercises
# --------------------------
data = generate(
types=[
"multiply_simple",
"multiply_three_terms",
"multiply_coefficients",
"fractional_nonunit",
"combine_same_power",
],
seed=42,
count=6,
show_solutions=False,
)
exercises = data["exercises"]
# --------------------------
# Clean metadata
# --------------------------
def clean_skills(skills):
return [s.replace("_", " ").capitalize() for s in skills]
for ex in exercises:
ex['meta_clean'] = {
'topic': ex['meta'].get('topic','Indices').replace("_"," ").capitalize(),
'skills': clean_skills(ex['meta'].get('skills', ['Index Laws']))
}
# --------------------------
# Group by difficulty
# --------------------------
grouped = defaultdict(list)
for ex in exercises:
grouped[ex["meta"]["difficulty"]].append(ex)
# --------------------------
# Function to render exercises as Markdown string
# --------------------------
def render_exercises_md(group, level):
md = ""
for ex in group.get(level, []):
md += f"::::: {{#exr-u2-{ex['number']}}}\n"
md += f"### {ex['title']}\n\n"
md += f"{ex['instruction']}\n\n"
# Question parts
for p in ex["parts"]:
math_delim = "$$" if p.get("is_wide") or level=="hard" else "$"
md += f"{p['label']})  {math_delim}{p['question_latex']}{math_delim}  \n"
md += "\n"
# Solution Callout
md += '::: {.callout-tip collapse="true"}\n'
md += "## 🔍 View Solution\n\n"
for p in ex["parts"]:
math_delim = "$$" if p.get("is_wide") or level=="hard" else "$"
md += f"{p['label']})  {math_delim}{p['answer_latex']}{math_delim}  \n"
md += ":::\n\n"
# Metadata footer
skills_str = "  \n".join(ex['meta_clean']['skills'])
md += f"::: exercise-meta\n[Topic: {ex['meta_clean']['topic']}]{{.badge .topic-badge}} [Skills: {skills_str}]{{.badge .skill-badge}}\n"
md += ":::\n\n"
md += ":::::\n\n"
return md
